GOMEMLIMIT=__GOMEMLIMIT__
PTXT_ADDR=__PTXT_ADDR__
PTXT_DB=__PTXT_DB__
PTXT_DEBUG=__PTXT_DEBUG__
PTXT_EVENT_RETENTION=__PTXT_EVENT_RETENTION__
PTXT_COMPACT_ON_START=__PTXT_COMPACT_ON_START__
# Slightly longer sweeps reduce steady CPU on small burstable hosts (trade: slower hydration freshness).
PTXT_HYDRATION_SWEEP_INTERVAL=6m
PTXT_TRENDING_SWEEP_INTERVAL=6m
PTXT_TRENDING_MIN_RECOMPUTE=20m
# Per-viewer trending warm loop is off by default (set to 1 on larger hosts).
PTXT_ACTIVE_VIEWER_TRENDING=0
PTXT_SEED_CRAWLER_ENABLED=true
# Seed crawler: wider interval + smaller batch lowers peak CPU during traffic spikes.
PTXT_SEED_CRAWLER_INTERVAL=30s
PTXT_SEED_CRAWLER_AUTHOR_BATCH=12
PTXT_SEED_CRAWLER_FETCH_LIMIT=60
PTXT_SEED_CRAWLER_AUTHOR_NOTE_LOOKBACK=2880h
PTXT_SEED_CRAWLER_REPLY_WARM_LIMIT=24
PTXT_SEED_CONTACT_FOLLOW_ENQUEUE_PER_TICK=120
PTXT_SQLITE_MAX_OPEN_CONNS=10
PTXT_SQLITE_MAX_IDLE_CONNS=4
PTXT_SQLITE_CACHE_KIB=32768
PTXT_SQLITE_MMAP_BYTES=134217728
PTXT_SQLITE_BUSY_TIMEOUT_MS=5000
PTXT_SQLITE_WAL_AUTOCHECKPOINT_PAGES=800
# pprof + expvar bound to loopback so on-host triage (SSM port-forward to
# 6060) can grab a goroutine/heap profile without flipping PTXT_DEBUG. Set to
# empty / "off" to disable.
PTXT_PPROF_ADDR=127.0.0.1:6060
# NIP-77 negentropy before REQ is opt-in (PTXT_NEGENTROPY=1); default in binary is off.
