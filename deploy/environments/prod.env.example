STACK_NAME=ptxt-nstr-prod
DOMAIN_NAME=example.com
# Optional dedicated CloudFront origin hostname; leave blank when CloudFront is not in use.
ORIGIN_DOMAIN_NAME=
# Where the apex DNS record points: DirectToEip (default) or CloudFrontAlias.
VIEWER_DNS_MODE=DirectToEip
# Required when VIEWER_DNS_MODE=CloudFrontAlias; CloudFront distribution domain name (e.g. d123abc.cloudfront.net).
CLOUDFRONT_DISTRIBUTION_DOMAIN_NAME=
# Optional: CloudFormation stack that owns the distribution (used after `make deploy` to invalidate /static/*).
# CLOUDFRONT_STACK_NAME=ptxt-nstr-cloudfront-prod
# Or set CLOUDFRONT_DISTRIBUTION_ID=E123... instead of resolving from the stack.
HOSTED_ZONE_ID=Z1234567890EXAMPLE
VPC_ID=vpc-xxxxxxxxxxxxxxxxx
SUBNET_ID=subnet-xxxxxxxxxxxxxxxxx
INSTANCE_TYPE=t4g.small
ROOT_VOLUME_SIZE_GIB=30
# Dedicated EBS data volume mounted at /var/lib/ptxt-nstr. Retained on stack
# delete so SQLite cache survives instance replacement and infra rollouts.
# Size/type only apply when creating a new volume; defaults below are safe to
# leave alone (they are ignored when EXISTING_DATA_VOLUME_ID is set).
# DATA_VOLUME_SIZE_GIB=20
# DATA_VOLUME_TYPE=gp3
# Optional: attach an existing retained volume by ID instead of creating a new
# one (e.g. recovery after `delete-stack`). Leave blank to create a fresh volume.
EXISTING_DATA_VOLUME_ID=
# Optional: pin the AZ for the data volume. When blank, deploy-cfn.sh auto-
# resolves it from SUBNET_ID via `aws ec2 describe-subnets`.
AVAILABILITY_ZONE=
ARTIFACT_BUCKET=your-artifact-bucket
ARTIFACT_PREFIX=ptxt-nstr/deploy
APP_USER=ptxt
CADDY_VERSION=2.9.1
GO_MEMORY_LIMIT=1GiB
EVENT_RETENTION=20000
DEBUG_ENABLED=false
COMPACT_ON_START=false
# Optional crawler tuning (defaults are set in artifact env template)
# PTXT_HYDRATION_SWEEP_INTERVAL=3m
# PTXT_TRENDING_SWEEP_INTERVAL=5m
# PTXT_TRENDING_MIN_RECOMPUTE=20m
# Keep per-viewer WoT trending_cache rows warm for signed-in feeds (recommended in prod).
# PTXT_ACTIVE_VIEWER_TRENDING=1
# PTXT_WOT_MAX_AUTHORS=240
# PTXT_SEED_CRAWLER_ENABLED=true
# PTXT_SEED_CRAWLER_INTERVAL=10s
# PTXT_SEED_CRAWLER_AUTHOR_BATCH=32
# PTXT_SEED_CRAWLER_FETCH_LIMIT=100
# PTXT_SEED_CRAWLER_AUTHOR_NOTE_LOOKBACK=2880h
# PTXT_SEED_CRAWLER_REPLY_WARM_LIMIT=24
# PTXT_SEED_CONTACT_FOLLOW_ENQUEUE_PER_TICK=120
# PTXT_SQLITE_MAX_OPEN_CONNS=10
# PTXT_SQLITE_MAX_IDLE_CONNS=4
# PTXT_SQLITE_CACHE_KIB=32768
# PTXT_SQLITE_MMAP_BYTES=134217728
# PTXT_SQLITE_BUSY_TIMEOUT_MS=5000
# PTXT_SQLITE_WAL_AUTOCHECKPOINT_PAGES=800
