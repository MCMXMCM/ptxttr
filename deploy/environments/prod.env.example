STACK_NAME=ptxt-nstr-prod
DOMAIN_NAME=example.com
HOSTED_ZONE_ID=Z1234567890EXAMPLE
VPC_ID=vpc-xxxxxxxxxxxxxxxxx
SUBNET_ID=subnet-xxxxxxxxxxxxxxxxx
INSTANCE_TYPE=t4g.small
ROOT_VOLUME_SIZE_GIB=30
ARTIFACT_BUCKET=your-artifact-bucket
ARTIFACT_PREFIX=ptxt-nstr/deploy
APP_USER=ptxt
CADDY_VERSION=2.9.1
GO_MEMORY_LIMIT=1GiB
EVENT_RETENTION=20000
DEBUG_ENABLED=false
COMPACT_ON_START=false
# Optional crawler tuning (defaults are set in artifact env template)
# PTXT_HYDRATION_SWEEP_INTERVAL=3m
# PTXT_TRENDING_SWEEP_INTERVAL=5m
# PTXT_TRENDING_MIN_RECOMPUTE=20m
# PTXT_SEED_CRAWLER_ENABLED=true
# PTXT_SEED_CRAWLER_INTERVAL=10s
# PTXT_SEED_CRAWLER_AUTHOR_BATCH=32
# PTXT_SEED_CRAWLER_FETCH_LIMIT=100
# PTXT_SEED_CRAWLER_AUTHOR_NOTE_LOOKBACK=2880h
# PTXT_SEED_CRAWLER_REPLY_WARM_LIMIT=24
# PTXT_SEED_CONTACT_FOLLOW_ENQUEUE_PER_TICK=120
# PTXT_SQLITE_MAX_OPEN_CONNS=10
# PTXT_SQLITE_MAX_IDLE_CONNS=4
# PTXT_SQLITE_CACHE_KIB=32768
# PTXT_SQLITE_MMAP_BYTES=134217728
# PTXT_SQLITE_BUSY_TIMEOUT_MS=5000
# PTXT_SQLITE_WAL_AUTOCHECKPOINT_PAGES=800
