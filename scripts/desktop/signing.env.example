# Copy this file to signing.env and fill in values. signing.env is gitignored.
#
#   cp scripts/desktop/signing.env.example scripts/desktop/signing.env
#
# Then run: make desktop-sign
# (after make desktop-build)
#
# Optional DMG filename version for make desktop-package / package-mac.sh
# (defaults to productVersion in cmd/desktop/wails.json if unset):
# PTXT_NSTR_DESKTOP='0.1.0'

# Required for codesign (full name or 40-char SHA-1 from security find-identity):
# DEVELOPER_ID_APPLICATION='Developer ID Application: Your Name (TEAMID)'

# Optional — Apple ID notarization (app-specific password from appleid.apple.com):
# APPLE_ID='you@example.com'
# APPLE_TEAM_ID='XXXXXXXXXX'
# APPLE_APP_SPECIFIC_PASSWORD='xxxx-xxxx-xxxx-xxxx'

# Optional — App Store Connect API key notarization instead of Apple ID:
# APPLE_API_KEY_PATH='/path/to/AuthKey_XXXXXX.p8'
# APPLE_API_KEY_ID='XXXXXXXXXX'
# APPLE_API_ISSUER='xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'
